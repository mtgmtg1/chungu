# ===== 앱 부트 환경변수 =====
# [Flow: Step 1 (compose가 .env 로드) -> Step 2 (backend/worker가 settings로 읽음)]

# --- 서비스 포트 (8080 선점됨 -> 28181 사용) ---
APP_PORT=28181

# --- 외부 접속 베이스 URL (이메일 다운로드 링크 생성에 사용) ---
# Cloudflare Tunnel 도메인이 있으면 그 주소로 교체
PUBLIC_BASE_URL=https://chungu.teamcat.app

# --- Supabase (셀프호스트 on a1) ---
# 내부 통신용 URL (Docker 네트워크 또는 localhost)
SUPABASE_URL=http://192.168.1.50:28000
# 외부 노출 URL (프론트엔드/signed URL에 사용, /supabase 프록시 경로 포함)
# 빈 값이면 SUPABASE_URL 사용
SUPABASE_PUBLIC_URL=https://chungu.teamcat.app/supabase
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=...

# --- 프론트엔드 빌드용 (docker compose build args) ---
# VITE_SUPABASE_URL은 더 이상 사용하지 않음 (런타임에 window.location.origin/supabase 사용)
VITE_SUPABASE_ANON_KEY=eyJ...

# --- 데이터베이스 (Supabase Postgres) ---
# supabase-network 내부에서 supabase-chungu-db 컨테이너로 접속
DATABASE_URL=postgresql+psycopg2://postgres:SUPABASE_POSTGRES_PASSWORD@supabase-chungu-db:5432/postgres

# --- Redis (Celery broker/result) ---
REDIS_URL=redis://redis:6379/0

# --- 민감 설정 암호화/세션 서명 키 (반드시 변경) ---
# 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=changeme_generate_a_long_random_secret

# --- 초기 관리자 계정 (최초 부팅 시 1회 시드) ---
ADMIN_EMAIL=mtgmtg@naver.com
ADMIN_INITIAL_PASSWORD=JDg629714!@

# --- 기본 LLM 설정 (이미지/PDF 파싱용 vLLM 프록시) ---
DEFAULT_LLM_ENDPOINT=http://192.168.1.69:18080/v1
DEFAULT_LLM_MODEL=cyankiwi/gemma-4-12B-it-qat-AWQ-INT4
DEFAULT_LLM_API_KEY=

# --- 미디어 전용 LLM (오디오/비디오 파싱용 Gemma-4 12B GGUF Q4_K_M on llama.cpp) ---
MEDIA_LLM_ENDPOINT=http://192.168.1.82:18080/v1
MEDIA_LLM_MODEL=unsloth/gemma-4-12b-it-GGUF
MEDIA_LLM_API_KEY=

# --- 업로드/작업 제한 ---
MAX_FILE_MB=200
MAX_PAGES=2000
DOWNLOAD_EXPIRE_DAYS=7

# --- 데이터 저장 경로 (컨테이너 내부) ---
DATA_DIR=/data
