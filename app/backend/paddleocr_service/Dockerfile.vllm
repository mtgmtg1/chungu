# [Flow: Step 1 (vLLM 소스 클론) -> Step 2 (CC 7.5 커널 컴파일) -> Step 3 (FP16 런타임 이미지)]
# RTX 2080 Ti (CC 7.5, Turing) 전용 vLLM Docker 이미지 빌드
# 사전 빌드 이미지(v0.9+)는 CC < 8.0 커널을 미포함하므로 소스 빌드 필요
#
# 빌드 명령 (b2 서버):
#   git clone https://github.com/vllm-project/vllm.git /tmp/vllm
#   cp Dockerfile.vllm /tmp/vllm/docker/Dockerfile.cc75
#   cd /tmp/vllm
#   DOCKER_BUILDKIT=1 docker build \
#     --target vllm-openai \
#     --tag vllm-cc75:latest \
#     --file docker/Dockerfile.cc75 \
#     --build-arg torch_cuda_arch_list="7.5" \
#     --build-arg max_jobs=4 \
#     --build-arg nvcc_threads=2 \
#     .

ARG CUDA_VERSION=12.6.0
ARG TORCH_CUDA_ARCH_LIST="7.5"

FROM --platform=linux/amd64 nvidia/cuda:${CUDA_VERSION}-devel-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
ENV TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST}
ENV MAX_JOBS=4
ENV NVCC_THREADS=2
ENV VLLM_TARGET_DEVICE=cuda

RUN apt-get update && apt-get install -y \
    python3.10 python3.10-dev python3-pip \
    git cmake ninja-build pkg-config \
    && ln -sf /usr/bin/python3.10 /usr/bin/python \
    && ln -sf /usr/bin/python3.10 /usr/bin/python3

RUN pip install --upgrade pip setuptools wheel

# PyTorch CUDA 12.6 설치
RUN pip install torch torchvision --index-url https://download.pytorch.org/whl/cu126

# vLLM 소스 클론 및 설치
RUN git clone --depth=1 https://github.com/vllm-project/vllm.git /vllm
WORKDIR /vllm

# CC 7.5 전용 커널 컴파일 (TORCH_CUDA_ARCH_LIST 환경 변수로 제어)
RUN pip install -e . --no-build-isolation

# 런타임 이미지
FROM --platform=linux/amd64 nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu22.04 AS vllm-openai

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    python3.10 python3.10-dev \
    libgomp1 \
    && ln -sf /usr/bin/python3.10 /usr/bin/python \
    && ln -sf /usr/bin/python3.10 /usr/bin/python3 \
    && rm -rf /var/lib/apt/lists/*

# builder에서 설치된 패키지 복사
COPY --from=builder /usr/local/lib/python3.10/dist-packages /usr/local/lib/python3.10/dist-packages
COPY --from=builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin
COPY --from=builder /vllm /vllm

WORKDIR /vllm

EXPOSE 8080

ENTRYPOINT ["vllm", "serve"]
